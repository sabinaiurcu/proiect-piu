<Window x:Class="Interface.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Agendă Telefonică"
        MinWidth="600" MinHeight="400"
        Width="1209" Height="818"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F8">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderBrush" Value="DarkGray"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#E8ECF0"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>


        <StackPanel Grid.Column="0" Background="#1B2A3B">
            <TextBlock Text="📋 Agenda"
                       Foreground="White" FontSize="15" FontWeight="Bold"
                       FontFamily="Segoe UI" Margin="10,24,10,20"
                       HorizontalAlignment="Center"/>

            <Button x:Name="btnMenuAdministrare" Content="Administrare"
                    Background="#2980B9" Foreground="White"
                    Margin="10,4" Padding="8,12"
                    Click="btnMenuAdministrare_Click"/>

            <Button x:Name="btnMenuCauta" Content="Caută"
                    Background="#2C3E50" Foreground="White"
                    Margin="10,4" Padding="8,12"
                    Click="btnMenuCauta_Click"/>

            <Button x:Name="btnMenuMesaje" Content="Mesaje"
                    Background="#2C3E50" Foreground="White"
                    Margin="10,4" Padding="8,12"
                    Click="btnMenuMesaje_Click"/>
        </StackPanel>


        <Grid x:Name="panelAdministrare" Grid.Column="1"
              Margin="16" Visibility="Visible">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="12"
                    BorderBrush="#E0E4EA" BorderThickness="1"
                    Margin="0,0,12,0" Padding="20">
                <StackPanel>
                    <Label Content="Contact nou" FontSize="15"
                           FontWeight="SemiBold" Padding="0,0,0,12"/>

                    <Label Content="Nume" Padding="0,0,0,2"/>
                    <TextBox Name="txtNume" Margin="0,0,0,10"
                             Text="{Binding ContactCurent.Nume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged,ValidatesOnDataErrors=True}"/>
                    <TextBlock Foreground="Red" FontSize="11" Margin="0,0,0,8"
           Text="{Binding ElementName=txtNume,
                  Path=(Validation.Errors)/ErrorContent}"/>

                    <Label Content="Prenume" Padding="0,0,0,2"/>
                    <TextBox Name="txtPrenume" Margin="0,0,0,10"
                             Text="{Binding ContactCurent.Prenume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged,ValidatesOnDataErrors=True}"/>
                    <TextBlock Foreground="Red" FontSize="11" Margin="0,0,0,8"
           Text="{Binding ElementName=txtPrenume,
                  Path=(Validation.Errors)/ErrorContent}"/>
                    <Label Content="Telefon" Padding="0,0,0,2"/>
                    <TextBox Name="txtTelefon" Margin="0,0,0,10"
                             Text="{Binding ContactCurent.Telefon, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>

                    <Label Content="Email" Padding="0,0,0,2"/>
                    <TextBox Name="txtEmail" Margin="0,0,0,10"
                             Text="{Binding ContactCurent.Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>
                   
                    <Label Content="Data nașterii" Padding="0,0,0,2"/>
                    <DatePicker x:Name="dtpDataNasterii"
                                Margin="0,0,0,10"
                                FontFamily="Segoe UI" FontSize="13"/>

                    <Label Content="Categorie" Padding="0,0,0,2"/>
                    <ComboBox x:Name="cmbCategorie"
                              Height="30" Margin="0,0,0,10"
                              FontFamily="Segoe UI" FontSize="13"/>

                    <Label Content="Metode de contact"
                           FontWeight="SemiBold" FontSize="14"
                           Padding="0,12,0,8"/>
                    <ListBox x:Name="lstMetode"
                             SelectionMode="Multiple" Height="80"
                             Margin="0,0,0,10" FontFamily="Segoe UI"
                             FontSize="13" BorderBrush="DarkGray"
                             BorderThickness="1" Background="#E8ECF0"/>

                    <Label Name="lblEroare" Content="" Foreground="#E74C3C"
                           FontWeight="Bold" FontSize="10" Padding="0,0,0,3"/>

                    <Button x:Name="btnAdauga" Content="Adaugă contact"
                            Background="#1B6CA8" Foreground="White"
                            Click="btnAdauga_Click" Height="32" Width="210"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="12"
                    BorderBrush="#E0E4EA" BorderThickness="1" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Content="Contacte salvate"
                           FontSize="15" FontWeight="SemiBold"
                           Padding="0,0,0,12"/>

                    <ListView Grid.Row="1" Name="listViewContacte"
                              BorderThickness="0"
                              FontFamily="Segoe UI" FontSize="13"
                              SelectionChanged="listViewContacte_SelectionChanged">
                        <ListView.Resources>
                            <Style TargetType="ListViewItem">
                                <Setter Property="BorderBrush" Value="#E0E4EA"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="Padding" Value="4,6"/>
                            </Style>
                        </ListView.Resources>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="ID" Width="40">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Id}" Width="40" TextAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Nume" Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Nume}" Width="100" TextAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Prenume" Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Prenume}" Width="100" TextAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Telefon" Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Telefon}" Width="100" TextAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Email" Width="130">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Email}" Width="130" TextAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Categorie" Width="80">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Categorie}" Width="80" TextAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>


                    <Button Grid.Row="2" x:Name="btnVeziMesaje"
                            Content="Vezi mesajele contactului selectat"
                            Background="#8E44AD" Foreground="White"
                            Height="32" Margin="0,10,0,0"
                            Visibility="Collapsed"
                            Click="btnVeziMesaje_Click"/>
                </Grid>
            </Border>
        </Grid>


        <Grid x:Name="panelCauta" Grid.Column="1"
              Margin="16" Visibility="Collapsed">
            <Border Background="White" CornerRadius="12"
                    BorderBrush="#E0E4EA" BorderThickness="1" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Content="Caută contact"
                           FontSize="15" FontWeight="SemiBold"
                           Padding="0,0,0,12"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal"
                                Margin="0,0,0,10">
                        <TextBox x:Name="txtCauta" Width="250"
                                 FontFamily="Segoe UI" FontSize="13"
                                 Padding="6,4" Margin="0,0,10,0"/>
                        <Button x:Name="btnCauta" Content="Caută"
                                Background="#1B6CA8" Foreground="White"
                                Height="32" Padding="16,0"
                                Click="btnCauta_Click"/>
                    </StackPanel>

                    <Label x:Name="lblCautaMsg" Grid.Row="2" Content=""
                           Foreground="#E74C3C" FontWeight="Bold"
                           FontSize="12" Padding="0,0,0,6"/>

                    <DataGrid x:Name="dgRezultate" Grid.Row="3"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              HeadersVisibility="Column" GridLinesVisibility="All"
                              AlternatingRowBackground="#F5F5F5" RowHeight="28"
                              FontFamily="Segoe UI" FontSize="13"
                              BorderBrush="#E0E4EA" BorderThickness="1">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Nume" Binding="{Binding Nume}" Width="120"/>
                            <DataGridTextColumn Header="Prenume" Binding="{Binding Prenume}" Width="120"/>
                            <DataGridTextColumn Header="Telefon" Binding="{Binding Telefon}" Width="110"/>
                            <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*"/>
                            <DataGridTextColumn Header="Categorie" Binding="{Binding Categorie}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>


        <Grid x:Name="panelMesaje" Grid.Column="1"
              Margin="16" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>


            <Border Grid.Column="0" Background="White" CornerRadius="12"
                    BorderBrush="#E0E4EA" BorderThickness="1"
                    Margin="0,0,12,0" Padding="20">
                <StackPanel>
                    <Label x:Name="lblTitluMesaj" Content="Mesaj nou"
                           FontSize="15" FontWeight="SemiBold"
                           Padding="0,0,0,10"/>

                    <Label x:Name="lblContactSelectat" Content=""
                           Foreground="#8E44AD" FontWeight="Bold"
                           FontSize="12" Padding="0,0,0,10"/>

                    <Label Content="Continut" Padding="0,0,0,2"/>
                    <TextBox x:Name="txtContinutMesaj" Margin="0,0,0,10"
                             Height="60" TextWrapping="Wrap"
                             AcceptsReturn="True"/>

                    <Label Content="Tip mesaj" Padding="0,0,0,2"/>
                    <ComboBox x:Name="cmbTipMesaj" Height="30"
                              Margin="0,0,0,10"
                              FontFamily="Segoe UI" FontSize="13"/>

                    <Label Content="Status" Padding="0,0,0,2"/>
                    <ComboBox x:Name="cmbStatusMesaj" Height="30"
                              Margin="0,0,0,10"
                              FontFamily="Segoe UI" FontSize="13"/>

                    <Label x:Name="lblEroareMesaj" Content=""
                           Foreground="#E74C3C" FontWeight="Bold"
                           FontSize="10" Padding="0,0,0,3"/>

                    <Button x:Name="btnAdaugaMesaj" Content="Adauga mesaj"
                            Background="#1B6CA8" Foreground="White"
                            Click="btnAdaugaMesaj_Click"
                            Height="32" Margin="0,0,0,6"/>

                    <Button x:Name="btnSalveazaMesaj" Content="Salveaza modificarile"
                            Background="#27AE60" Foreground="White"
                            Click="btnSalveazaMesaj_Click"
                            Height="32" Margin="0,0,0,6"
                            Visibility="Collapsed"/>

                    <Button x:Name="btnAnuleazaMesaj" Content="Anuleaza"
                            Background="#95A5A6" Foreground="White"
                            Click="btnAnuleazaMesaj_Click"
                            Height="28" Visibility="Collapsed"/>
                </StackPanel>
            </Border>


            <Border Grid.Column="1" Background="White" CornerRadius="12"
                    BorderBrush="#E0E4EA" BorderThickness="1" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Content="Mesaje"
                           FontSize="15" FontWeight="SemiBold"
                           Padding="0,0,0,12"/>

                    <ListView Grid.Row="1" x:Name="listViewMesaje"
                              BorderThickness="0"
                              FontFamily="Segoe UI" FontSize="12">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="ID" Width="35">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Id}" TextAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Continut" Width="120">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Continut}" TextTrimming="CharacterEllipsis"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Tip" Width="65">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Tip}" TextAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Status" Width="65">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Status}" TextAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Edit" Width="50">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="✏️" Width="40" Height="22"
                                                    Background="#F39C12" Foreground="White"
                                                    BorderThickness="0" Cursor="Hand"
                                                    Tag="{Binding Id}"
                                                    Click="btnEditeazaMesaj_Click"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Sterge" Width="55">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="🗑️" Width="40" Height="22"
                                                    Background="#E74C3C" Foreground="White"
                                                    BorderThickness="0" Cursor="Hand"
                                                    Tag="{Binding Id}"
                                                    Click="btnStergeMesaj_Click"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</Window>