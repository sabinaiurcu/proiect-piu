<Window x:Class="Interface.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Agendă Telefonică"
        Height="600" Width="820"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F8">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="6 4"/>
            <Setter Property="BorderBrush" Value="DarkGray"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#E8ECF0"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16 6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White"
                CornerRadius="12" BorderBrush="#E0E4EA"
                BorderThickness="1" Margin="0 0 12 0"
                Padding="20">
            <StackPanel>
                <Label Content="Contact nou" FontSize="15"
                       FontWeight="SemiBold" Padding="0 0 0 12"/>

                <Label Content="Nume" Padding="0 0 0 2"/>
                <TextBox Name="txtNume" Margin="0 0 0 10"/>

                <Label Content="Prenume" Padding="0 0 0 2"/>
                <TextBox Name="txtPrenume" Margin="0 0 0 10"/>

                <Label Content="Telefon" Padding="0 0 0 2"/>
                <TextBox Name="txtTelefon" Margin="0 0 0 10"/>

                <Label Content="Email" Padding="0 0 0 2"/>
                <TextBox Name="txtEmail" Margin="0 0 0 10"/>

                <Label Content="Categorie" Padding="0 0 0 2"/>
                <ComboBox Name="cmbCategorie" Margin="0 0 0 10"
                          FontFamily="Segoe UI" FontSize="13"
                          Padding="6 4"
                          Background="#E8ECF0"/>

                <Label Content="Metode de contact"
                       FontWeight="SemiBold"
                       FontSize="15"
                       Padding="0 16 0 13"/>
                <CheckBox Name="chkTelefon" Content="Telefon"
                          Margin="0 0 0 4" FontFamily="Segoe UI"
                          FontSize="13"/>
                <CheckBox Name="chkEmail" Content="Email"
                          Margin="0 0 0 4" FontFamily="Segoe UI"
                          FontSize="13"/>
                <CheckBox Name="chkWhatsApp" Content="WhatsApp"
                          Margin="0 0 0 16" FontFamily="Segoe UI"
                          FontSize="13"/>

                <Label Name="lblEroare" Content="" Foreground="#E74C3C"
                       FontWeight="Bold"
                       FontSize="10" Padding="0 0 0 3"/>

                <Button x:Name="btnAdauga" Content="Adaugă contact"
                        Background="#1B6CA8" Foreground="White"
                        Click="btnAdauga_Click" Height="32" Width="210"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="White"
                CornerRadius="12" BorderBrush="#E0E4EA"
                BorderThickness="1" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Label Grid.Row="0" Content="Contacte salvate"
                       FontSize="15" FontWeight="SemiBold"
                       Padding="0 0 0 12"/>

                <ListView Grid.Row="1" Name="listViewContacte"
                          BorderThickness="0"
                          FontFamily="Segoe UI" FontSize="13">
                    <ListView.Resources>
                        <Style TargetType="ListViewItem">
                            <Setter Property="BorderBrush" Value="#E0E4EA"/>
                            <Setter Property="BorderThickness" Value="0 0 0 1"/>
                            <Setter Property="Padding" Value="4 6"/>
                        </Style>
                    </ListView.Resources>
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="ID" Width="40">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Id}" TextAlignment="Center" Width="40"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Nume" Width="100">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Nume}" TextAlignment="Center" Width="100"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Prenume" Width="100">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Prenume}" TextAlignment="Center" Width="100"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Telefon" Width="100">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Telefon}" TextAlignment="Center" Width="100"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Email" Width="160">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Email}" TextAlignment="Center" Width="160"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Categorie" Width="80">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Categorie}" TextAlignment="Center" Width="80"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Window>