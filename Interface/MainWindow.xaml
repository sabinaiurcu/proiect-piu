<Window x:Class="Interface.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Agendă Telefonică"
        MinWidth="600" MinHeight="400"
        Width="900" Height="620"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F8">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderBrush" Value="DarkGray"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#E8ECF0"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>

    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        
        <StackPanel Grid.Column="0" Background="#1B2A3B">

            <TextBlock Text="📋 Agenda"
                       Foreground="White"
                       FontSize="15"
                       FontWeight="Bold"
                       FontFamily="Segoe UI"
                       Margin="10,24,10,20"
                       HorizontalAlignment="Center"/>

            <Button x:Name="btnMenuAdministrare"
                    Content="Administrare"
                    Background="#2980B9"
                    Foreground="White"
                    Margin="10,4"
                    Padding="8,12"
                    Click="btnMenuAdministrare_Click"/>

            <Button x:Name="btnMenuCauta"
                    Content="Caută"
                    Background="#2C3E50"
                    Foreground="White"
                    Margin="10,4"
                    Padding="8,12"
                    Click="btnMenuCauta_Click"/>

        </StackPanel>

        <Grid x:Name="panelAdministrare"
              Grid.Column="1"
              Margin="16"
              Visibility="Visible">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

           
            <Border Grid.Column="0" Background="White"
                    CornerRadius="12" BorderBrush="#E0E4EA"
                    BorderThickness="1" Margin="0,0,12,0"
                    Padding="20">
                <StackPanel>
                    <Label Content="Contact nou" FontSize="15"
                           FontWeight="SemiBold" Padding="0,0,0,12"/>

                    <Label Content="Nume" Padding="0,0,0,2"/>
                    <TextBox Name="txtNume" Margin="0,0,0,10"/>

                    <Label Content="Prenume" Padding="0,0,0,2"/>
                    <TextBox Name="txtPrenume" Margin="0,0,0,10"/>

                    <Label Content="Telefon" Padding="0,0,0,2"/>
                    <TextBox Name="txtTelefon" Margin="0,0,0,10"/>

                    <Label Content="Email" Padding="0,0,0,2"/>
                    <TextBox Name="txtEmail" Margin="0,0,0,10"/>


                    <Label Content="Categorie" Padding="0,0,0,6"/>
                    <WrapPanel Margin="0,0,0,10">
                        <RadioButton x:Name="rbFamilie"
                 Content="Familie"
                 GroupName="Categorie"
                 IsChecked="True"
                 FontFamily="Segoe UI" FontSize="13"
                 Margin="0,0,12,6"/>
                        <RadioButton x:Name="rbServciu"
                 Content="Serviciu"
                 GroupName="Categorie"
                 FontFamily="Segoe UI" FontSize="13"
                 Margin="0,0,12,6"/>
                        <RadioButton x:Name="rbPrieten"
                 Content="Prieten"
                 GroupName="Categorie"
                 FontFamily="Segoe UI" FontSize="13"
                 Margin="0,0,12,6"/>
                        <RadioButton x:Name="rbAltele"
                 Content="Altele"
                 GroupName="Categorie"
                 FontFamily="Segoe UI" FontSize="13"
                 Margin="0,0,0,6"/>
                    </WrapPanel>

                    <Label Content="Metode de contact"
                           FontWeight="SemiBold" FontSize="14"
                           Padding="0,12,0,8"/>
                    <CheckBox Name="chkTelefon" Content="Telefon"
                              Margin="0,0,0,4" FontFamily="Segoe UI" FontSize="13"/>
                    <CheckBox Name="chkEmail" Content="Email"
                              Margin="0,0,0,4" FontFamily="Segoe UI" FontSize="13"/>
                    <CheckBox Name="chkWhatsApp" Content="WhatsApp"
                              Margin="0,0,0,16" FontFamily="Segoe UI" FontSize="13"/>

                    <Label Name="lblEroare" Content="" Foreground="#E74C3C"
                           FontWeight="Bold" FontSize="10" Padding="0,0,0,3"/>

                    <Button x:Name="btnAdauga" Content="Adaugă contact"
                            Background="#1B6CA8" Foreground="White"
                            Click="btnAdauga_Click" Height="32" Width="210"/>
                </StackPanel>
            </Border>

            
            <Border Grid.Column="1" Background="White"
                    CornerRadius="12" BorderBrush="#E0E4EA"
                    BorderThickness="1" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Content="Contacte salvate"
                           FontSize="15" FontWeight="SemiBold"
                           Padding="0,0,0,12"/>

                    <ListView Grid.Row="1" Name="listViewContacte"
                              BorderThickness="0"
                              FontFamily="Segoe UI" FontSize="13">
                        <ListView.Resources>
                            <Style TargetType="ListViewItem">
                                <Setter Property="BorderBrush" Value="#E0E4EA"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="Padding" Value="4,6"/>
                            </Style>
                        </ListView.Resources>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="ID" Width="40">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Id}" Width="40" TextAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Nume" Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Nume}" Width="100" TextAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Prenume" Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Prenume}" Width="100" TextAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Telefon" Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Telefon}" Width="100" TextAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Email" Width="160">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Email}" Width="160" TextAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Categorie" Width="80">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Categorie}" Width="80" TextAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="panelCauta"
      Grid.Column="1"
      Margin="16"
      Visibility="Collapsed">

            <Border Background="White" CornerRadius="12"
            BorderBrush="#E0E4EA" BorderThickness="1" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    
                    <Label Grid.Row="0" Content="Caută contact"
                   FontSize="15" FontWeight="SemiBold"
                   Padding="0,0,0,12"/>

                    
                    <StackPanel Grid.Row="1" Orientation="Horizontal"
                        Margin="0,0,0,10">
                        <TextBox x:Name="txtCauta"
                         Width="250"
                         FontFamily="Segoe UI" FontSize="13"
                         Padding="6,4"
                         Margin="0,0,10,0"/>
                        <Button x:Name="btnCauta"
                        Content="Caută"
                        Background="#1B6CA8" Foreground="White"
                        Height="32" Padding="16,0"
                        Click="btnCauta_Click"/>
                    </StackPanel>

                    
                    <Label x:Name="lblCautaMsg"
                   Grid.Row="2"
                   Content=""
                   Foreground="#E74C3C"
                   FontWeight="Bold"
                   FontSize="12"
                   Padding="0,0,0,6"/>

                    <DataGrid x:Name="dgRezultate"
                      Grid.Row="3"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="All"
                      AlternatingRowBackground="#F5F5F5"
                      RowHeight="28"
                      FontFamily="Segoe UI"
                      FontSize="13"
                      BorderBrush="#E0E4EA"
                      BorderThickness="1">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"
                                        Binding="{Binding Id}"
                                        Width="50"/>
                            <DataGridTextColumn Header="Nume"
                                        Binding="{Binding Nume}"
                                        Width="120"/>
                            <DataGridTextColumn Header="Prenume"
                                        Binding="{Binding Prenume}"
                                        Width="120"/>
                            <DataGridTextColumn Header="Telefon"
                                        Binding="{Binding Telefon}"
                                        Width="110"/>
                            <DataGridTextColumn Header="Email"
                                        Binding="{Binding Email}"
                                        Width="*"/>
                            <DataGridTextColumn Header="Categorie"
                                        Binding="{Binding Categorie}"
                                        Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>

                </Grid>
            </Border>
        </Grid>

    </Grid>
</Window>